<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Projet L4INA01 - ELKASMI Soukaina</title>
    <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>

    <div id="cv-bloc">
        <div class="cv-gauche">
            <h1>Curriculum Vitae</h1>
            <h3>Soukaina Elkasmi</h3>
            <p><strong>Parcours scolaire :</strong></p>
            <table border="1" style="border-collapse: collapse; background: white; width: 100%;">
                <tr><td>2024-2025</td><td>L1 Sciences du Langage</td></tr>
                <tr><td>2025-2026</td><td>L2 Sciences du Langage</td></tr>
            </table>

            <p><strong>Livres lus :</strong></p>
            <ul>
                <li>La dame de ménage</li>
                <li>Harry Potter</li>
                <li>Linguistique et Société</li>
                <li>La structure des langues</li>
                <li>Analyse du discours</li>
            </ul>
        </div>
        <div class="cv-droite">
            <img src="assets/img/maphoto.jpg" alt="Photo" style="width:100px; border:1px solid black; display:block; margin-bottom:5px;">
            <img src="assets/img/universite.jpg" alt="Ecole" style="width:100px; border:1px solid black;">
        </div>
    </div>

    <div id="analyseur-bloc">
        <h3>Analyse des données dans un fichier</h3>
        <p>Fichier .txt : <input type="file" id="fileInput"></p>

        <table style="margin: auto; text-align: left;">
            <tr>
                <td>DÉLIMITEURS:</td>
                <td><input type="text" id="delims" value="[ ,.?;:!/()&quot;']+"></td>
            </tr>
            <tr>
                <td>PÔLE:</td>
                <td><input type="text" id="pole"></td>
                <td>LONGUEUR:</td>
                <td><input type="number" id="longueur" value="10"></td>
            </tr>
        </table>

        <div style="margin: 15px;">
            <button id="btnBonjour">Bonjour</button>
        </div>

        <div class="boutons">
            <button id="btnSegmentation">Segmentation</button>
            <button id="btnDico">Dictionnaire</button>
            <button id="btnGrep">GREP</button>
            <button id="btnConc">Concordancier</button>
        </div>

        <div class="affichage">
            <textarea id="affichageGauche"></textarea>
            <div id="affichageDroit"></div>
        </div>
        <p id="stats">Nombre de formes : 0</p>
    </div>

    <script src="assets/js/main.js"></script>
</body>
</html>
